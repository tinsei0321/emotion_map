# ════════════ 本地密钥配置（每台机器各写一次，互不影响）════════════
#
# 用法（每台机器一次）：
#   复制本文件为 .env（同目录），填入本机可用的 key 即可。
#   - .env 已在 .gitignore（第 16 行）—— 绝不进 git，永不交叉泄露。
#   - api/main.py 启动时自动加载 .env（_load_env_file，不覆盖已有系统环境变量）。
#   - 办公室/家庭两台机器各自的 .env 独立，无需来回换 key。
#
# 不填的 key 留空或删掉即可（对应功能退化为不可用，不影响其他）。

# ── DeepSeek（AI 问答 LLM · 必填，否则问答报"未配置 LLM API Key"）──
DEEPSEEK_API_KEY=

# ── 高德（地理编码 / POI 兜底 · 服务端读，绝不进前端）──
AMAP_KEY=

# ── 火山引擎 Ark（备用 LLM / 视觉）──
ARK_API_KEY=

# ── 讯飞（备用 LLM / 校对）──
IFLYTEK_API_KEY=

# ── 调试令牌（如启用）──
DEBUG_KEY=
