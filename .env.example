# ════════════ 本地密钥配置（每台机器各写一次，互不影响）════════════
#
# 用法（每台机器一次）：
#   复制本文件为 .env（同目录），填入本机可用的 key 即可。
#   - .env 已在 .gitignore（第 16 行）—— 绝不进 git，永不交叉泄露。
#   - api/main.py 启动时自动加载 .env（_load_env_file，不覆盖已有系统环境变量）。
#   - 办公室/家庭两台机器各自的 .env 独立，无需来回换 key。
#
# 不填的 key 留空或删掉即可（对应功能退化为不可用，不影响其他）。

# ── LLM provider 链（ai_qa/llm.py chat_with_fallback：主链路 + 审查员共用）──
#   主 = DeepSeek；备 1 = 火山 Ark；备 2 = 讯飞。空 key 自动跳过。
#   主家拨不通自动重拨 3 次（1/2/4 秒），仍不通按序换备用家；仅配 DEEPSEEK_API_KEY 时行为不变。
#   每家的 *_MODEL_PRO / *_MODEL_FLASH 可选覆盖（Pro=旗舰推理 / Flash=快速经济·审查员用）。

# 主：DeepSeek（OpenAI 兼容 /v1 · 必填，否则问答报"无可用 LLM provider"）
DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL_PRO=deepseek-v4-pro
# DEEPSEEK_MODEL_FLASH=deepseek-v4-flash

# ── 高德（地理编码 / POI 兜底 · 服务端读，绝不进前端）──
AMAP_KEY=

# 备 1：火山引擎 Ark（LLM fallback / 视觉；OpenAI 兼容 /api/v3，model 填 endpoint id 或 doubao 名）
ARK_API_KEY=
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# ARK_MODEL_PRO=doubao-pro-32k
# ARK_MODEL_FLASH=doubao-lite-32k

# 备 2：讯飞 Spark（LLM fallback / 校对；OpenAI 兼容 /v1）
IFLYTEK_API_KEY=
# IFLYTEK_BASE_URL=https://spark-api-open.xfyun.cn/v1
# IFLYTEK_MODEL_PRO=4.0Ultra
# IFLYTEK_MODEL_FLASH=generalv3

# ── 调试令牌（如启用）──
DEBUG_KEY=
